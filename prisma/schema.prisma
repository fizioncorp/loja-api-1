generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  barcode   String   @unique
  price     Float
  cost      Float
  stock     Int      @default(0)
  createdAt DateTime @default(now())

  movements StockMovement[]
}

model StockMovement {
  id        String   @id @default(uuid())
  productId String
  type      MovementType
  quantity  Int
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id])
}

enum MovementType {
  IN
  OUT
}