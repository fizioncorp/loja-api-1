generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  barcode   String   @unique
  price     Float
  cost      Float
  stock     Int      @default(0)
  createdAt DateTime @default(now())

  movements StockMovement[]
  saleItems SaleItem[]

  storeId String
  store   Store @relation(fields: [storeId], references: [id])
}

model StockMovement {
  id        String   @id @default(uuid())
  productId String
  type      MovementType
  quantity  Int
  createdAt DateTime @default(now())

  product   Product  @relation(fields: [productId], references: [id])
}

enum MovementType {
  IN
  OUT
}

model Sale {
  id        String   @id @default(uuid())
  total     Float
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())

  items     SaleItem[]
  status String @default("COMPLETED")
}

model SaleItem {
  id        String   @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  price     Float

  sale      Sale     @relation(fields: [saleId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}

model Store {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users     User[]
  products  Product[]
  sales     Sale[]
  
  cashRegisters CashRegister[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  storeId   String
  createdAt DateTime @default(now())

  store     Store    @relation(fields: [storeId], references: [id])
}

model CashRegister {
  id        String   @id @default(uuid())
  storeId   String
  openedAt  DateTime @default(now())
  closedAt  DateTime?
  initial   Float
  sales     Float    @default(0)

  store Store @relation(fields: [storeId], references: [id])
}