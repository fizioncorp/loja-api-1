generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(uuid())
  name      String
  barcode   String   @unique
  price     Float
  cost      Float
  stock     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  movements StockMovement[]
  saleItems SaleItem[]

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])
}

model StockMovement {
  id        String @id @default(cuid())
  storeId   String
  productId String
  userId    String

  type     MovementType
  quantity Int

  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

model Sale {
  id        String   @id @default(uuid())
  total     Float
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())

  items  SaleItem[]
  payments Payment[]
  status String     @default("COMPLETED")
}

model SaleItem {
  id        String @id @default(uuid())
  saleId    String
  productId String
  quantity  Int
  price     Float

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Store {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  products Product[]
  sales    Sale[]

  cashRegisters CashRegister[]
  StockMovement StockMovement[]
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  storeId   String
  createdAt DateTime @default(now())

  store         Store           @relation(fields: [storeId], references: [id])
  StockMovement StockMovement[]
}

model CashRegister {
  id       String    @id @default(uuid())
  storeId  String
  openedAt DateTime  @default(now())
  closedAt DateTime?
  initial  Float
  sales    Float     @default(0)

  store Store @relation(fields: [storeId], references: [id])
}


enum PaymentMethod {
  PIX
  CASH
  CARD
}

model Payment {
  id        String   @id @default(cuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])
}

